# ── RBI Web Isolation 환경변수 ──────────────────────────────
# .env.example 을 복사해 .env 로 저장 후 운영 환경에 맞게 수정하세요.
# cp .env.example .env

# ── 게이트웨이 ───────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# ★ 운영 배포 시 반드시 랜덤 값으로 교체
JWT_SECRET=CHANGE_ME_RANDOM_256BIT_SECRET
COOKIE_SECURE=false          # HTTPS 운영 환경에서는 true
BCRYPT_ROUNDS=12

# 최초 부팅 시 생성되는 관리자 계정 (첫 로그인 후 즉시 비밀번호 변경)
BOOTSTRAP_ADMIN=admin
BOOTSTRAP_PASSWORD=changeme

# ── RBCloud Browser (격리 브라우저) ─────────────────────────
RBCLOUD_URL=http://rbcloud:8080
RBCLOUD_WS_PATH=/api/ws
CDP_HOST=rbcloud
CDP_PORT=9222
RBI_HOMEPAGE=about:blank

# RBCloud Browser 접속 비밀번호 (사용자용 / 관리자용)
RBCLOUD_PASSWORD=userpass
RBCLOUD_ADMIN_PASSWORD=adminpass

# WebRTC: 서버의 외부 IP 또는 도메인
RBCLOUD_WEBRTC_NAT1TO1=127.0.0.1
# WebRTC UDP 포트 범위 (방화벽에서 오픈 필요)
RBCLOUD_WEBRTC_UDPMUX=52000

# ── 성능 튜닝 (저사양 서버) ──────────────────────────────────
# 세션 화면 해상도@프레임. 영상 인코딩이 세션당 CPU 코어를 점유하므로,
# 코어가 적은 서버(예: 4코어)는 낮출수록 동시 세션 수를 늘릴 수 있음.
#   1920x1080@30  : 최고 화질, 부하 큼
#   1280x720@25   : 권장(기본). 1080p 대비 인코딩 부하 ~절반
#   1024x768@20   : 더 가벼움(저사양/다세션)
RBI_DESKTOP_SCREEN=1280x720@25
# 동시 세션 상한 (하드웨어 한계 초과 방지). 4코어 i5면 2~3 권장.
RBI_MAX_SESSIONS=50

# ── CDR 엔진 (선택) ──────────────────────────────────────────
# 외부 CDR 무해화 REST 서비스 URL.  비워두면 CDR 정책은 pass-through.
CDR_ENGINE_URL=

# ── 로그 ─────────────────────────────────────────────────────
LOG_LEVEL=info
